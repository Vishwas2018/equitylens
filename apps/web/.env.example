# Supabase — get these from the Supabase dashboard (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Server-only (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Database (direct connection — used by migration scripts and server actions)
# Get from Settings → Database → Connection string → URI
DATABASE_URL=postgres://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
