{
  "name": "equitylens",
  "private": true,
  "engines": {
    "node": "^20.14.0"
  },
  "packageManager": "pnpm@9.4.0",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:cctv": "tsx scripts/audit-cctv.ts",
    "audit:deps": "tsx scripts/audit-deps.ts",
    "db:migrate:dryrun": "tsx scripts/db-migrate-dryrun.ts",
    "db:migrate:lint": "tsx scripts/db-migrate-lint.ts",
    "test:rls": "vitest run --config tests/vitest.config.ts",
    "prepare": "husky"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@next/swc-win32-x64-msvc",
      "unrs-resolver"
    ],
    "overrides": {
      "glob": ">=10.5.0"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "19.3.0",
    "@commitlint/config-conventional": "19.2.2",
    "@playwright/test": "^1.60.0",
    "@supabase/supabase-js": "^2.106.0",
    "@types/node": "20.14.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.29",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-unused-imports": "3.2.0",
    "husky": "9.1.4",
    "lint-staged": "15.2.7",
    "pg": "^8.21.0",
    "prettier": "3.3.3",
    "tsx": "4.16.2",
    "turbo": "^2",
    "typescript": "5.5.4",
    "vitest": "^1.6.1"
  }
}
